---
import { getCollection } from 'astro:content';
import OrgLayout from '../../layouts/OrgLayout.astro';
import TerrorOrgLayout from '../../layouts/TerrorOrgLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('organizations');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const isTerror = entry.data.type === 'Organizacja terrorystyczna';
---

{isTerror ? (
  <TerrorOrgLayout entry={entry} headings={headings}>
    <Content />
  </TerrorOrgLayout>
) : (
  <OrgLayout entry={entry} headings={headings}>
    <Content />
  </OrgLayout>
)}
