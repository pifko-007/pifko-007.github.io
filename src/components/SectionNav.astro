---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const h2s = headings.filter(h => h.depth === 2);
---

<nav class="section-nav">
  {h2s.map((h, i) => (
    <a href={`#${h.slug}`} class={i === 0 ? 'active' : ''}>{h.text}</a>
  ))}
</nav>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        document.querySelectorAll('.section-nav a, .sidebar-nav a').forEach(a => {
          a.classList.toggle('active', a.getAttribute('href') === '#' + id);
        });
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  document.querySelectorAll('.entry-content h2').forEach(h => obs.observe(h));
</script>
