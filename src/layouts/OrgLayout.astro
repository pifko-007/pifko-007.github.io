---
import BaseLayout from './BaseLayout.astro';
import SectionNav from '../components/SectionNav.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'organizations'>;
  headings: { depth: number; slug: string; text: string }[];
}

const { entry, headings } = Astro.props;
const { name, flag, type, founded, headquarters, members, tags } = entry.data;
const h2s = headings.filter(h => h.depth === 2);
---

<BaseLayout title={name}>
  <div class="app">
    <aside class="sidebar">
      <div class="sidebar-header">{name}</div>
      <nav class="sidebar-nav">
        {h2s.map((h, i) => (
          <a href={`#${h.slug}`} class={i === 0 ? 'active' : ''}>
            <span class="section-dot"></span>{h.text}
          </a>
        ))}
      </nav>
    </aside>

    <main class="content">
      <a class="back-btn" href="/">← Powrót do listy</a>

      <div class="page-header">
        <div class="breadcrumb">
          <a href="/">GeoAtlas</a> / <a href="/">Organizacje</a> / {name}
        </div>
        <h1>{flag} {name}</h1>
        <div class="page-header-meta">
          <div class="meta-item"><span>Typ:</span><strong>{type}</strong></div>
          <div class="meta-item"><span>Założona:</span><strong>{founded}</strong></div>
          <div class="meta-item"><span>Siedziba:</span><strong>{headquarters}</strong></div>
          <div class="meta-item"><span>Członkowie:</span><strong>{members}</strong></div>
          <div class="card-tags">
            {tags.map(tag => <span class="tag org">{tag}</span>)}
          </div>
        </div>
      </div>

      <SectionNav headings={headings} />

      <div class="entry-content entry-section-end">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>

<style is:global>
  /* Override accent for org pages */
  .page-header .tag.org { background: var(--org-tag); color: var(--org-accent); }
  .section-nav a.active { border-bottom-color: var(--org-accent); color: var(--org-accent); }
  .sidebar-nav a.active { color: var(--org-accent); background: rgba(74,90,156,0.07); border-left-color: var(--org-accent); }
  .sidebar-nav a.active .section-dot { background: var(--org-accent); }
</style>
