---
import GlobalNav from '../components/GlobalNav.astro';

interface Props {
  title?: string;
}

const { title = 'GeoAtlas' } = Astro.props;
---

<!doctype html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — GeoAtlas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <GlobalNav />
  <slot />
</body>
</html>

<style is:global>
  :root {
    --bg: #0a0c10;
    --surface: #111318;
    --surface2: #181c24;
    --border: #1e2330;
    --accent: #c8a96e;
    --accent2: #4a7fa5;
    --text: #d4d8e2;
    --text-muted: #6b7280;
    --text-dim: #9ca3af;
    --country-tag: #1a2a1a;
    --country-accent: #4a8c5c;
    --org-tag: #1a1a2e;
    --org-accent: #4a5a9c;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Sans', sans-serif;
    font-weight: 300;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* GRAIN OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* ── GLOBAL NAV ─────────────────────────────── */
  .global-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(10, 12, 16, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    height: 56px;
  }

  .nav-brand {
    padding: 0 28px;
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.05em;
    border-right: 1px solid var(--border);
    height: 100%;
    display: flex;
    align-items: center;
    white-space: nowrap;
    text-decoration: none;
  }

  .nav-brand span {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 0.8rem;
    margin-left: 8px;
    font-family: 'IBM Plex Mono', monospace;
  }

  .nav-sections {
    display: flex;
    height: 100%;
    flex: 1;
  }

  .nav-group {
    position: relative;
    height: 100%;
  }

  .nav-group-btn {
    height: 100%;
    padding: 0 20px;
    background: none;
    border: none;
    border-right: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-group-btn:hover,
  .nav-group-btn.open {
    color: var(--accent);
    background: rgba(200, 169, 110, 0.05);
  }

  .nav-group-btn .arrow {
    font-size: 0.6rem;
    transition: transform 0.2s;
  }

  .nav-group-btn.open .arrow { transform: rotate(180deg); }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: 56px; left: 0;
    min-width: 200px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: none;
    z-index: 200;
  }

  .nav-dropdown.open { display: block; }

  .nav-dropdown a {
    display: block;
    padding: 10px 18px;
    color: var(--text-dim);
    text-decoration: none;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 0.85rem;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s, background 0.15s;
  }

  .nav-dropdown a:last-child { border-bottom: none; }
  .nav-dropdown a:hover { color: var(--accent); background: rgba(200, 169, 110, 0.05); }

  /* ── APP LAYOUT ─────────────────────────────── */
  .app {
    display: flex;
    min-height: 100vh;
    padding-top: 56px;
  }

  /* ── SIDEBAR ─────────────────────────────────── */
  .sidebar {
    width: 260px;
    min-width: 260px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    position: sticky;
    top: 56px;
    height: calc(100vh - 56px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .sidebar-header {
    padding: 20px 20px 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  .sidebar-nav a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 20px;
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.85rem;
    border-bottom: 1px solid rgba(30, 35, 48, 0.5);
    transition: all 0.15s;
  }

  .sidebar-nav a:hover { color: var(--text); background: rgba(255, 255, 255, 0.03); }

  .sidebar-nav a.active {
    color: var(--accent);
    background: rgba(200, 169, 110, 0.07);
    border-left: 2px solid var(--accent);
    padding-left: 18px;
  }

  .sidebar-nav .section-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
  }

  .sidebar-nav a.active .section-dot { background: var(--accent); }

  /* ── CONTENT ─────────────────────────────────── */
  .content {
    flex: 1;
    min-width: 0;
  }

  /* ── HOME ─────────────────────────────────── */
  .hero {
    padding: 80px 60px 60px;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: 'GEO';
    position: absolute;
    right: -20px; top: -40px;
    font-family: 'Playfair Display', serif;
    font-size: 18rem;
    font-weight: 900;
    color: rgba(200, 169, 110, 0.03);
    pointer-events: none;
    line-height: 1;
  }

  .hero-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 3.2rem;
    font-weight: 900;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 20px;
    max-width: 600px;
  }

  .hero p {
    color: var(--text-muted);
    max-width: 520px;
    font-size: 0.95rem;
  }

  .stats-bar {
    display: flex;
    border-top: 1px solid var(--border);
  }

  .stat {
    padding: 24px 40px;
    border-right: 1px solid var(--border);
  }

  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .cards-section {
    padding: 48px 60px;
  }

  .section-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 48px;
  }

  .card {
    background: var(--surface);
    padding: 24px;
    cursor: pointer;
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: block;
    animation: fadeUp 0.4s ease both;
  }

  .card:hover { background: var(--surface2); }

  .card-type {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .card-type.country { color: var(--country-accent); }
  .card-type.org { color: var(--org-accent); }

  .card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .card-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.6rem;
    padding: 3px 8px;
    letter-spacing: 0.1em;
  }

  .tag.country { background: var(--country-tag); color: var(--country-accent); }
  .tag.org { background: var(--org-tag); color: var(--org-accent); }

  .card-arrow {
    position: absolute;
    right: 20px; bottom: 20px;
    color: var(--border);
    font-size: 1.2rem;
    transition: color 0.2s, transform 0.2s;
  }

  .card:hover .card-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  /* nth-child delays */
  .card:nth-child(1) { animation-delay: 0.05s; }
  .card:nth-child(2) { animation-delay: 0.1s; }
  .card:nth-child(3) { animation-delay: 0.15s; }
  .card:nth-child(4) { animation-delay: 0.2s; }
  .card:nth-child(5) { animation-delay: 0.25s; }

  /* ── PAGE VIEW ───────────────────────────────── */
  .page-header {
    padding: 48px 60px 36px;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .breadcrumb {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .breadcrumb a {
    color: var(--accent);
    text-decoration: none;
  }

  .breadcrumb a:hover { text-decoration: underline; }

  .page-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 900;
    color: #fff;
    margin-bottom: 12px;
  }

  .page-header-meta {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    align-items: center;
  }

  .meta-item {
    font-size: 0.82rem;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .meta-item strong {
    color: var(--text);
    font-weight: 500;
  }

  /* STICKY SECTION NAV */
  .section-nav {
    position: sticky;
    top: 56px;
    z-index: 50;
    background: rgba(10, 12, 16, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    display: flex;
    overflow-x: auto;
  }

  .section-nav a {
    padding: 14px 22px;
    color: var(--text-muted);
    text-decoration: none;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-right: 1px solid var(--border);
    white-space: nowrap;
    transition: color 0.2s, background 0.2s;
  }

  .section-nav a:hover { color: var(--accent); background: rgba(200, 169, 110, 0.05); }
  .section-nav a.active { color: var(--accent); border-bottom: 2px solid var(--accent); }

  /* ENTRY CONTENT (rendered markdown) */
  .entry-content {
    padding: 0 60px;
  }

  .entry-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #fff;
    padding-top: 52px;
    margin-bottom: 6px;
    scroll-margin-top: 112px;
  }

  .entry-content h2:not(:first-of-type) {
    border-top: 1px solid var(--border);
    margin-top: 4px;
  }

  .entry-content h2::after {
    content: attr(id);
    display: block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 400;
    margin-top: 4px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .entry-content h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin: 24px 0 8px;
  }

  .entry-content p {
    color: var(--text-dim);
    margin-bottom: 1rem;
    max-width: 72ch;
  }

  .entry-content ul,
  .entry-content ol {
    color: var(--text-dim);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .entry-content li { margin-bottom: 4px; }

  .entry-content a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(200, 169, 110, 0.4);
  }

  .entry-content strong { color: var(--text); font-weight: 500; }

  .entry-content code {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85em;
    background: var(--surface);
    padding: 2px 6px;
    color: var(--accent);
  }

  .entry-content blockquote {
    border-left: 3px solid var(--accent);
    padding: 12px 20px;
    margin: 16px 0;
    background: var(--surface);
    color: var(--text-dim);
    font-style: italic;
  }

  .entry-section-end {
    padding-bottom: 52px;
  }

  /* MAP */
  .country-map {
    margin: 0 0 32px;
    padding: 24px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-align: center;
  }

  .country-map img {
    max-width: 100%;
    max-height: 360px;
    object-fit: contain;
    border-radius: 2px;
  }

  .country-map figcaption {
    margin-top: 10px;
    font-size: 11px;
    font-family: 'IBM Plex Mono', monospace;
    color: var(--text-muted);
  }

  /* BACK BUTTON */
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 24px 60px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .back-btn:hover { color: var(--accent); border-color: var(--accent); }

  /* ── HAMBURGER ───────────────────────────────── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 56px;
    height: 56px;
    padding: 0 18px;
    background: none;
    border: none;
    border-left: 1px solid var(--border);
    cursor: pointer;
    margin-left: auto;
    flex-shrink: 0;
  }

  .nav-hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-dim);
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── MOBILE MENU ─────────────────────────────── */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--bg);
    flex-direction: column;
    overflow: hidden;
  }

  .mobile-menu.open { display: flex; }

  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .mobile-menu-close {
    width: 56px;
    height: 56px;
    background: none;
    border: none;
    border-left: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .mobile-menu-body {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mobile-section-label {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--surface);
    border: none;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .mobile-section-label .arrow {
    font-size: 0.6rem;
    transition: transform 0.2s;
  }

  .mobile-section.open .mobile-section-label .arrow { transform: rotate(180deg); }

  .mobile-section-body {
    display: none;
  }

  .mobile-section.open .mobile-section-body { display: block; }

  .mobile-link {
    display: block;
    padding: 13px 24px;
    color: var(--text-dim);
    text-decoration: none;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 0.9rem;
    border-bottom: 1px solid rgba(30, 35, 48, 0.5);
    transition: color 0.15s, background 0.15s;
  }

  .mobile-link:hover { color: var(--text); background: rgba(255, 255, 255, 0.03); }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .sidebar { display: none; }
  }

  @media (max-width: 700px) {
    .nav-sections { display: none; }
    .nav-hamburger { display: flex; }
    .hero { padding: 48px 24px 36px; }
    .hero h1 { font-size: 2rem; }
    .cards-section { padding: 32px 24px; }
    .page-header { padding: 32px 24px 24px; }
    .entry-content { padding: 0 24px; }
    .section-nav a { padding: 12px 14px; }
    .back-btn { margin: 16px 24px; }
    .stat { padding: 16px 24px; }
  }
</style>
